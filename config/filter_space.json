  "compatibility_rules": [
    {"when": {"parameter": "resize_scale", "operator": "lt", "value": 1.0}, "require": {"parameter": "canvas_mode", "operator": "ne", "value": "none"}, "message": "dezoom requires an active canvas mode"},
    {"when": {"parameter": "zoom", "operator": "gt", "value": 1.0}, "forbid": {"parameter": "resize_scale", "operator": "lt", "value": 1.0}, "message": "zoom and dezoom cannot be active together"},
    {"when": {"parameter": "zoom", "operator": "gt", "value": 1.018}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.012}, "message": "large crop and zoom cannot be combined"},
    {"when": {"parameter": "rotation_degrees", "operator": "gt", "value": 1.0}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.016}, "message": "maximum rotation and crop cannot be combined"},
    {"when": {"parameter": "rotation_degrees", "operator": "lt", "value": -1.0}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.016}, "message": "maximum rotation and crop cannot be combined"},
    {"when": {"parameter": "resize_scale", "operator": "lt", "value": 0.975}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.01}, "message": "strong dezoom and crop cannot be combined"},
    {"when": {"parameter": "resize_scale", "operator": "lt", "value": 0.975}, "forbid": {"parameter": "canvas_padding_x", "operator": "gt", "value": 0.02}, "message": "strong dezoom and maximum canvas cannot be combined"},
    {"when": {"parameter": "resize_scale", "operator": "lt", "value": 0.975}, "forbid": {"parameter": "uniform_frame_width", "operator": "gt", "value": 0.012}, "message": "strong dezoom and maximum frame cannot be combined"},
    {"when": {"parameter": "offset_x", "operator": "gt", "value": 0.016}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.012}, "message": "large offset and crop cannot be combined"},
    {"when": {"parameter": "offset_x", "operator": "lt", "value": -0.016}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.012}, "message": "large offset and crop cannot be combined"},
    {"when": {"parameter": "offset_y", "operator": "gt", "value": 0.016}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.012}, "message": "large offset and crop cannot be combined"},
    {"when": {"parameter": "offset_y", "operator": "lt", "value": -0.016}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.012}, "message": "large offset and crop cannot be combined"},
    {"when": {"parameter": "canvas_mode", "operator": "ne", "value": "none"}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.01}, "message": "canvas cannot be combined with significant crop"},
    {"when": {"parameter": "canvas_mode", "operator": "ne", "value": "none"}, "forbid": {"parameter": "zoom", "operator": "gt", "value": 1.01}, "message": "canvas cannot be combined with significant zoom"},
    {
      "when": {"parameter": "grayscale_blend", "operator": "gt", "value": 0},
      "forbid": {"parameter": "sepia_blend", "operator": "gt", "value": 0},
      "message": "grayscale and sepia blends cannot be active together"
    }
  ]
