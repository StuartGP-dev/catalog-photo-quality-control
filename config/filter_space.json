{
  "version": 5,
  "proposal_allocation": {
    "random": 0.50,
    "proven": 0.30,
    "mutation": 0.20
  },
  "quality_thresholds": {
    "minimum_quality": 0.55,
    "maximum_active_parameters": 4,
    "maximum_recipe_intensity": 1.2,
    "maximum_pixel_mae": 0.06,
    "maximum_luminance_mae": 0.06,
    "minimum_ssim": 0.90,
    "minimum_perceptual_geometry_ssim": 0.72,
    "maximum_sharpness_ratio": 1.6,
    "minimum_sharpness_ratio": 0.7,
    "maximum_clip_fraction": 0.08
  },
  "selection_pool_multiplier": 3,
  "diversity_gate": {
    "enabled": true,
    "compare_same_image_index_only": true,
    "include_ready_variants": true,
    "include_source_images": true,
    "reject_complete_variant_on_single_image_failure": true,
    "engine_version": "perceptual-consensus-o18-v1",
    "hash_size": 8,
    "band_limits": {
      "phash": {"strong": 4, "review": 10, "weak": 16},
      "dhash": {"strong": 4, "review": 10, "weak": 16},
      "whash": {"strong": 4, "review": 10, "weak": 18}
    },
    "reject_verdicts": ["exact", "same", "near_duplicate"],
    "reject_original_verdicts": ["exact", "same", "near_duplicate"],
    "consensus": {"same_strong_count": 3, "near_strong_count": 2, "near_review_count": 2},
    "nearest_neighbors_to_persist": 3
  },
  "geometry_template_probability": 0.9,
  "parameters": {
    "brightness": {"type": "float", "enabled": true, "default": 1.0, "min": 0.88, "max": 1.12, "activation_probability": 0.42, "distribution": "triangular"},
    "contrast": {"type": "float", "enabled": true, "default": 1.0, "min": 0.85, "max": 1.15, "activation_probability": 0.42, "distribution": "triangular"},
    "saturation": {"type": "float", "enabled": true, "default": 1.0, "min": 0.88, "max": 1.12, "activation_probability": 0.3, "distribution": "triangular"},
    "sharpness": {"type": "float", "enabled": true, "default": 1.0, "min": 0.85, "max": 1.25, "activation_probability": 0.18, "distribution": "triangular"},
    "gamma": {"type": "float", "enabled": true, "default": 1.0, "min": 0.88, "max": 1.12, "activation_probability": 0.28, "distribution": "triangular"},
    "warmth": {"type": "float", "enabled": true, "default": 0.0, "min": -0.08, "max": 0.08, "activation_probability": 0.25, "distribution": "triangular"},
    "tint": {"type": "float", "enabled": true, "default": 0.0, "min": -0.05, "max": 0.05, "activation_probability": 0.16, "distribution": "triangular"},
    "autocontrast_blend": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.08, "activation_probability": 0.08, "distribution": "uniform"},
    "equalize_blend": {"type": "float", "enabled": false, "default": 0.0, "min": 0.0, "max": 0.08, "activation_probability": 0.0, "distribution": "uniform"},
    "horizontal_mirror": {"type": "choice", "enabled": true, "default": "off", "choices": ["off", "on"], "activation_probability": 0.14, "distribution": "choice"},
    "rotation_degrees": {"type": "float", "enabled": true, "default": 0.0, "min": -8.0, "max": 8.0, "active_min_abs": 0.5, "activation_probability": 0.55, "distribution": "triangular"},
    "crop_fraction": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.12, "active_min": 0.005, "activation_probability": 0.45, "distribution": "uniform"},
    "zoom": {"type": "float", "enabled": true, "default": 1.0, "min": 1.0, "max": 1.20, "active_min": 1.005, "activation_probability": 0.48, "distribution": "triangular"},
    "offset_x": {"type": "float", "enabled": true, "default": 0.0, "min": -0.12, "max": 0.12, "active_min_abs": 0.01, "activation_probability": 0.38, "distribution": "triangular"},
    "offset_y": {"type": "float", "enabled": true, "default": 0.0, "min": -0.12, "max": 0.12, "active_min_abs": 0.01, "activation_probability": 0.38, "distribution": "triangular"},
    "resize_scale": {"type": "float", "enabled": true, "default": 1.0, "min": 0.80, "max": 1.0, "active_max": 0.99, "activation_probability": 0.4, "distribution": "triangular"},
    "shear_x": {"type": "float", "enabled": true, "default": 0.0, "min": -0.10, "max": 0.10, "active_min_abs": 0.015, "activation_probability": 0.18, "distribution": "triangular"},
    "shear_y": {"type": "float", "enabled": true, "default": 0.0, "min": -0.08, "max": 0.08, "active_min_abs": 0.015, "activation_probability": 0.16, "distribution": "triangular"},
    "perspective_x": {"type": "float", "enabled": true, "default": 0.0, "min": -0.08, "max": 0.08, "active_min_abs": 0.01, "activation_probability": 0.16, "distribution": "triangular"},
    "perspective_y": {"type": "float", "enabled": true, "default": 0.0, "min": -0.06, "max": 0.06, "active_min_abs": 0.01, "activation_probability": 0.14, "distribution": "triangular"},
    "gaussian_blur_radius": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.25, "activation_probability": 0.025, "distribution": "uniform"},
    "median_size": {"type": "int", "enabled": false, "default": 1, "min": 1, "max": 5, "activation_probability": 0.0, "distribution": "choice"},
    "unsharp_radius": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.4, "activation_probability": 0.06, "distribution": "uniform"},
    "unsharp_percent": {"type": "int", "enabled": true, "default": 100, "min": 80, "max": 115, "activation_probability": 0.06, "distribution": "uniform"},
    "sepia_blend": {"type": "float", "enabled": false, "default": 0.0, "min": 0.0, "max": 0.45, "activation_probability": 0.0, "distribution": "uniform"},
    "grayscale_blend": {"type": "float", "enabled": false, "default": 0.0, "min": 0.0, "max": 1.0, "activation_probability": 0.0, "distribution": "uniform"},
    "red_gain": {"type": "float", "enabled": true, "default": 1.0, "min": 0.985, "max": 1.015, "activation_probability": 0.08, "distribution": "triangular"},
    "green_gain": {"type": "float", "enabled": true, "default": 1.0, "min": 0.985, "max": 1.015, "activation_probability": 0.08, "distribution": "triangular"},
    "blue_gain": {"type": "float", "enabled": true, "default": 1.0, "min": 0.985, "max": 1.015, "activation_probability": 0.08, "distribution": "triangular"},
    "canvas_mode": {"type": "choice", "enabled": true, "default": "none", "choices": ["none", "white", "light_gray", "sampled_background", "sampled_edge", "side_bands", "uniform_frame"], "activation_probability": 0.42, "distribution": "choice"},
    "canvas_padding_x": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.03, "activation_probability": 0.0, "distribution": "triangular"},
    "canvas_padding_y": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.018, "activation_probability": 0.0, "distribution": "triangular"},
    "side_band_width": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.035, "activation_probability": 0.0, "distribution": "triangular"},
    "uniform_frame_width": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.02, "activation_probability": 0.0, "distribution": "triangular"},
    "fixed_background_gray": {"type": "int", "enabled": true, "default": 246, "min": 238, "max": 250, "activation_probability": 0.0, "distribution": "triangular"},
    "sampled_color_strength": {"type": "float", "enabled": true, "default": 0.9, "min": 0.75, "max": 1.0, "activation_probability": 0.0, "distribution": "triangular"},
    "sampled_edge_fraction": {"type": "float", "enabled": true, "default": 0.08, "min": 0.05, "max": 0.12, "activation_probability": 0.0, "distribution": "triangular"},
    "sampled_saturation_limit": {"type": "float", "enabled": true, "default": 0.18, "min": 0.12, "max": 0.25, "activation_probability": 0.0, "distribution": "triangular"},
    "sampled_lightness_minimum": {"type": "float", "enabled": true, "default": 0.7, "min": 0.62, "max": 0.82, "activation_probability": 0.0, "distribution": "triangular"},
    "canvas_alignment": {"type": "choice", "enabled": false, "default": "center", "choices": ["center"], "activation_probability": 0.0, "distribution": "choice"},
    "canvas_resample_method": {"type": "choice", "enabled": false, "default": "lanczos", "choices": ["lanczos"], "activation_probability": 0.0, "distribution": "choice"},
    "border_width": {"type": "int", "enabled": false, "default": 0, "min": 0, "max": 4, "activation_probability": 0.0, "distribution": "uniform"},
    "rounded_radius": {"type": "int", "enabled": false, "default": 0, "min": 0, "max": 80, "activation_probability": 0.0, "distribution": "uniform"},
    "jpeg_quality": {"type": "int", "enabled": true, "default": 93, "min": 90, "max": 96, "activation_probability": 1.0, "distribution": "triangular"}
  },
  "compatibility_rules": [
    {"when": {"parameter": "resize_scale", "operator": "lt", "value": 1.0}, "require": {"parameter": "canvas_mode", "operator": "ne", "value": "none"}, "message": "dezoom requires an active canvas mode"},
    {"when": {"parameter": "zoom", "operator": "gt", "value": 1.0}, "forbid": {"parameter": "resize_scale", "operator": "lt", "value": 1.0}, "message": "zoom and dezoom cannot be active together"},
    {"when": {"parameter": "zoom", "operator": "gt", "value": 1.12}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.06}, "message": "extreme crop and zoom cannot be combined"},
    {"when": {"parameter": "rotation_degrees", "operator": "gt", "value": 6.0}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.08}, "message": "extreme rotation and crop cannot be combined"},
    {"when": {"parameter": "rotation_degrees", "operator": "lt", "value": -6.0}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.08}, "message": "extreme rotation and crop cannot be combined"},
    {
      "when": {"parameter": "grayscale_blend", "operator": "gt", "value": 0},
      "forbid": {"parameter": "sepia_blend", "operator": "gt", "value": 0},
      "message": "grayscale and sepia blends cannot be active together"
    }
  ]
}
