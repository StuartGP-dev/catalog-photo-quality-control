    {"when": {"parameter": "offset_y", "operator": "gt", "value": 0.009}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.008}, "message": "large offset and crop cannot be combined"},
    {"when": {"parameter": "offset_y", "operator": "lt", "value": -0.009}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.008}, "message": "large offset and crop cannot be combined"},
    {"when": {"parameter": "canvas_mode", "operator": "ne", "value": "none"}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.008}, "message": "canvas cannot be combined with significant crop"},
    {"when": {"parameter": "canvas_mode", "operator": "ne", "value": "none"}, "forbid": {"parameter": "zoom", "operator": "gt", "value": 1.012}, "message": "canvas cannot be combined with significant zoom"},
