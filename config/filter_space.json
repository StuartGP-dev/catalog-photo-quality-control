{
  "version": 2,
  "proposal_allocation": {
    "random": 0.5,
    "proven": 0.3,
    "mutation": 0.2
  },
  "quality_thresholds": {
    "minimum_quality": 0.55,
    "maximum_active_parameters": 4,
    "maximum_recipe_intensity": 1.35,
    "maximum_pixel_mae": 0.055,
    "maximum_luminance_mae": 0.045,
    "minimum_ssim": 0.97,
    "maximum_sharpness_ratio": 1.8,
    "minimum_sharpness_ratio": 0.55,
    "maximum_clip_fraction": 0.035
  },
  "selection_pool_multiplier": 3,
  "parameters": {
    "brightness": {"type": "float", "enabled": true, "default": 1.0, "min": 0.97, "max": 1.03, "activation_probability": 0.32, "distribution": "triangular"},
    "contrast": {"type": "float", "enabled": true, "default": 1.0, "min": 0.96, "max": 1.04, "activation_probability": 0.32, "distribution": "triangular"},
    "saturation": {"type": "float", "enabled": true, "default": 1.0, "min": 0.96, "max": 1.04, "activation_probability": 0.25, "distribution": "triangular"},
    "sharpness": {"type": "float", "enabled": true, "default": 1.0, "min": 0.97, "max": 1.08, "activation_probability": 0.12, "distribution": "triangular"},
    "gamma": {"type": "float", "enabled": true, "default": 1.0, "min": 0.97, "max": 1.03, "activation_probability": 0.2, "distribution": "triangular"},
    "warmth": {"type": "float", "enabled": true, "default": 0.0, "min": -0.025, "max": 0.025, "activation_probability": 0.16, "distribution": "triangular"},
    "tint": {"type": "float", "enabled": true, "default": 0.0, "min": -0.015, "max": 0.015, "activation_probability": 0.12, "distribution": "triangular"},
    "autocontrast_blend": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.08, "activation_probability": 0.08, "distribution": "uniform"},
    "equalize_blend": {"type": "float", "enabled": false, "default": 0.0, "min": 0.0, "max": 0.08, "activation_probability": 0.0, "distribution": "uniform"},
    "rotation_degrees": {"type": "float", "enabled": true, "default": 0.0, "min": -0.8, "max": 0.8, "activation_probability": 0.12, "distribution": "triangular"},
    "crop_fraction": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.015, "activation_probability": 0.08, "distribution": "uniform"},
    "zoom": {"type": "float", "enabled": true, "default": 1.0, "min": 0.985, "max": 1.015, "activation_probability": 0.1, "distribution": "triangular"},
    "offset_x": {"type": "float", "enabled": true, "default": 0.0, "min": -0.01, "max": 0.01, "activation_probability": 0.06, "distribution": "triangular"},
    "offset_y": {"type": "float", "enabled": true, "default": 0.0, "min": -0.01, "max": 0.01, "activation_probability": 0.06, "distribution": "triangular"},
    "resize_scale": {"type": "float", "enabled": true, "default": 1.0, "min": 0.98, "max": 1.0, "activation_probability": 0.06, "distribution": "triangular"},
    "gaussian_blur_radius": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.25, "activation_probability": 0.025, "distribution": "uniform"},
    "median_size": {"type": "int", "enabled": false, "default": 1, "min": 1, "max": 5, "activation_probability": 0.0, "distribution": "choice"},
    "unsharp_radius": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.4, "activation_probability": 0.06, "distribution": "uniform"},
    "unsharp_percent": {"type": "int", "enabled": true, "default": 100, "min": 80, "max": 115, "activation_probability": 0.06, "distribution": "uniform"},
    "sepia_blend": {"type": "float", "enabled": false, "default": 0.0, "min": 0.0, "max": 0.45, "activation_probability": 0.0, "distribution": "uniform"},
    "grayscale_blend": {"type": "float", "enabled": false, "default": 0.0, "min": 0.0, "max": 1.0, "activation_probability": 0.0, "distribution": "uniform"},
    "red_gain": {"type": "float", "enabled": true, "default": 1.0, "min": 0.985, "max": 1.015, "activation_probability": 0.08, "distribution": "triangular"},
    "green_gain": {"type": "float", "enabled": true, "default": 1.0, "min": 0.985, "max": 1.015, "activation_probability": 0.08, "distribution": "triangular"},
    "blue_gain": {"type": "float", "enabled": true, "default": 1.0, "min": 0.985, "max": 1.015, "activation_probability": 0.08, "distribution": "triangular"},
    "canvas_mode": {"type": "choice", "enabled": true, "default": "none", "choices": ["none", "white", "light_gray", "sampled_background", "sampled_edge", "side_bands", "uniform_frame"], "activation_probability": 0.32, "distribution": "choice"},
    "canvas_padding_x": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.03, "activation_probability": 0.0, "distribution": "triangular"},
    "canvas_padding_y": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.018, "activation_probability": 0.0, "distribution": "triangular"},
    "side_band_width": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.035, "activation_probability": 0.0, "distribution": "triangular"},
    "uniform_frame_width": {"type": "float", "enabled": true, "default": 0.0, "min": 0.0, "max": 0.02, "activation_probability": 0.0, "distribution": "triangular"},
    "fixed_background_gray": {"type": "int", "enabled": true, "default": 246, "min": 238, "max": 250, "activation_probability": 0.0, "distribution": "triangular"},
    "sampled_color_strength": {"type": "float", "enabled": true, "default": 0.9, "min": 0.75, "max": 1.0, "activation_probability": 0.0, "distribution": "triangular"},
    "sampled_edge_fraction": {"type": "float", "enabled": true, "default": 0.08, "min": 0.05, "max": 0.12, "activation_probability": 0.0, "distribution": "triangular"},
    "sampled_saturation_limit": {"type": "float", "enabled": true, "default": 0.18, "min": 0.12, "max": 0.25, "activation_probability": 0.0, "distribution": "triangular"},
    "sampled_lightness_minimum": {"type": "float", "enabled": true, "default": 0.7, "min": 0.62, "max": 0.82, "activation_probability": 0.0, "distribution": "triangular"},
    "canvas_alignment": {"type": "choice", "enabled": false, "default": "center", "choices": ["center"], "activation_probability": 0.0, "distribution": "choice"},
    "canvas_resample_method": {"type": "choice", "enabled": false, "default": "lanczos", "choices": ["lanczos"], "activation_probability": 0.0, "distribution": "choice"},
    "border_width": {"type": "int", "enabled": false, "default": 0, "min": 0, "max": 4, "activation_probability": 0.0, "distribution": "uniform"},
    "rounded_radius": {"type": "int", "enabled": false, "default": 0, "min": 0, "max": 80, "activation_probability": 0.0, "distribution": "uniform"},
    "jpeg_quality": {"type": "int", "enabled": true, "default": 93, "min": 90, "max": 96, "activation_probability": 1.0, "distribution": "triangular"}
  },
  "compatibility_rules": [
    {"when": {"parameter": "canvas_mode", "operator": "ne", "value": "none"}, "forbid": {"parameter": "crop_fraction", "operator": "gt", "value": 0.01}, "message": "canvas cannot be combined with significant crop"},
    {"when": {"parameter": "canvas_mode", "operator": "ne", "value": "none"}, "forbid": {"parameter": "zoom", "operator": "gt", "value": 1.01}, "message": "canvas cannot be combined with significant zoom"},
    {
      "when": {"parameter": "grayscale_blend", "operator": "gt", "value": 0},
      "forbid": {"parameter": "sepia_blend", "operator": "gt", "value": 0},
      "message": "grayscale and sepia blends cannot be active together"
    }
  ]
}
