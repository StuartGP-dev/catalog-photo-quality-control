# Shared DB between PCs. Prefer PostgreSQL for real multi-PC work.
# Example via Tailscale:
# CATALOG_DB_DSN=postgresql://catalog_user:catalog_password@100.x.x.x:5432/catalog_filter_engine

# Local fallback for smoke tests / single PC only:
CATALOG_DB_DSN=sqlite:///local/catalog_filter_engine/catalog_filters.sqlite3

# Source annonces root
CATALOG_PHOTO_ANNONCES_ROOT=C:\\Users\\yanis\\Documents\\Code\\Bot\\annonces

# Generated outputs root
CATALOG_PHOTO_OUTPUT_ROOT=local/catalog_filter_engine
